# 環境変数設定ファイル

# ===== ブラウザ（Vite）用 =====
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===== scripts/（データパイプライン）用 =====
# Supabase Postgres接続文字列（Drizzle / drizzle-kit 共用）
# 形式: postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=your-database-url

# Storage画像アップロード用（サービスロールキー。ブラウザには絶対に出さない）
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
